<!-- ARM fragment: worldbody children only, included inside scene.xml -->
<body name="base" pos="0 0 0.05">
  <geom type="cylinder" size="0.05 0.05" rgba="0.3 0.3 0.3 1"
        contype="0" conaffinity="0"/>

  <body name="link1" pos="0 0 0.05">
    <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14"
           damping="2.0" armature="0.1"/>
    <geom type="capsule" fromto="0 0 0 0 0 0.18" size="0.025"
          rgba="0.4 0.4 0.8 1" contype="0" conaffinity="0"/>

    <body name="link2" pos="0 0 0.18">
      <joint name="joint2" type="hinge" axis="0 1 0" range="-1.57 1.57"
             damping="2.0" armature="0.1"/>
      <geom type="capsule" fromto="0 0 0 0.22 0 0" size="0.022"
            rgba="0.4 0.4 0.8 1" contype="0" conaffinity="0"/>

      <body name="link3" pos="0.22 0 0">
        <joint name="joint3" type="hinge" axis="0 1 0" range="-2.0 2.0"
               damping="2.0" armature="0.1"/>
        <geom type="capsule" fromto="0 0 0 0.18 0 0" size="0.018"
              rgba="0.4 0.4 0.8 1" contype="0" conaffinity="0"/>

        <body name="gripper_base" pos="0.18 0 0">
          <!-- Palm disc: cylinder for symmetric 3-finger silhouette -->
          <geom type="cylinder" size="0.028 0.010" pos="0 0 -0.010"
                rgba="0.5 0.5 0.5 1" contype="0" conaffinity="0"/>

          <!-- Three fingers at 120° spacing, independently actuated.
               Each has its own position actuator (act_grip_a/b/c) in scene.xml
               and an actuatorfrc sensor (grip_force / grip_b_force / grip_c_force)
               for per-finger effort monitoring.

               finger_a: contype=1 — primary contact finger (explicit pair in scene.xml)
               finger_b/c: contype=0 — structural/visual; independent position control
                 enables adaptive B/C closure profile (GRIP_CONFIRM margin post-weld).

               Each finger carries a fingertip site for the touch sensor array.

               Geometry (gripper_base frame, q=0):
                 finger_a: (  0,    -0.040, -0.020)  slide +Y  → closes to R≈0.020
                 finger_b: (+0.035, +0.020, -0.020)  slide (-0.866,-0.500, 0)
                 finger_c: (-0.035, +0.020, -0.020)  slide (+0.866,-0.500, 0) -->

          <!-- Finger A — primary functional finger (0°, −Y side) -->
          <body name="finger_a" pos="0 -0.040 -0.020">
            <joint name="finger_left_joint" type="slide" axis="0 1 0"
                   range="0 0.035" damping="1.0"/>
            <geom name="finger_a_geom" type="capsule"
                  fromto="0 0 -0.030 0 0 0.010" size="0.009"
                  friction="2.0 0.2 0.01" contype="1" conaffinity="1"
                  rgba="0.8 0.6 0.2 1"/>
            <!-- Fingertip site: at capsule top cap → contact force sensor reads here -->
            <site name="tip_a" pos="0 0 0.010" size="0.005" rgba="1 0.3 0 1"/>
          </body>

          <!-- Finger B (120° CCW from A) — structural/visual; independent position control -->
          <body name="finger_b" pos="0.0346 0.020 -0.020">
            <inertial pos="0 0 0" mass="0.001" diaginertia="1e-7 1e-7 1e-7"/>
            <joint name="finger_b_joint" type="slide" axis="-0.866 -0.500 0"
                   range="0 0.035" damping="0.1"/>
            <geom name="finger_b_geom" type="capsule"
                  fromto="0 0 -0.030 0 0 0.010" size="0.009"
                  density="0" contype="0" conaffinity="0" rgba="0.8 0.6 0.2 1"/>
            <site name="tip_b" pos="0 0 0.010" size="0.005" rgba="0.2 0.9 0.2 1"/>
          </body>

          <!-- Finger C (240° CCW from A) — structural/visual; independent position control -->
          <body name="finger_c" pos="-0.0346 0.020 -0.020">
            <inertial pos="0 0 0" mass="0.001" diaginertia="1e-7 1e-7 1e-7"/>
            <joint name="finger_c_joint" type="slide" axis="0.866 -0.500 0"
                   range="0 0.035" damping="0.1"/>
            <geom name="finger_c_geom" type="capsule"
                  fromto="0 0 -0.030 0 0 0.010" size="0.009"
                  density="0" contype="0" conaffinity="0" rgba="0.8 0.6 0.2 1"/>
            <site name="tip_c" pos="0 0 0.010" size="0.005" rgba="0.2 0.4 1 1"/>
          </body>

          <!-- EE site: position unchanged → IK parameters (_IK_L3EFF, _IK_DOFF)
               and all pre-computed _WP joint angles remain valid. -->
          <site name="ee" pos="0.01 0 -0.052" size="0.006" rgba="1 0 0 1"/>

          <!-- Gripper-eye camera: 80 mm above palm, looking down at fingertips/egg.
               Available via --camera gripper_cam in run_interactive.py. -->
          <camera name="gripper_cam" pos="0 0 0.08" xyaxes="1 0 0 0 1 0"/>
        </body>
      </body>
    </body>
  </body>
</body>
